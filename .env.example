APP_NAME=Bangumi Anime Reception Analyst
APP_ENV=dev
API_PREFIX=/api/v1
OUTPUT_ROOT=outputs

BANGUMI_BASE_URL=https://api.bgm.tv
BANGUMI_TOKEN=your_bangumi_access_token_here
BANGUMI_USER_AGENT=BangumiAnimeReceptionAnalyst/0.1 (your-email-or-github)
BANGUMI_TIMEOUT_SECONDS=30
BANGUMI_REQUEST_PAUSE_SECONDS=0.2

AGENT_MODEL=vertex_ai/gemini-2.5-flash
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=us-central1

# Use your existing ADC / gcloud auth setup, or point to a service account file if needed:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
